---
import BaseLayout from "../layouts/BaseLayout.astro";
import LegalLinks from "../components/LegalLinks.astro";
import SiteHeader from "../components/SiteHeader.astro";

const navLinks = [
  { href: "/#about", label: "about" },
  { href: "/#gallery", label: "gallery" },
  { href: "/sign-up/", label: "sign up" },
];

const currentYear = new Date().getFullYear();
---

<BaseLayout
  allowMotion={false}
  lang="fr"
  title="OSMK | Mentions légales"
  description="Mentions légales du site vitrine OSMK."
>
  <main class="legal-page">
    <SiteHeader navLinks={navLinks} locale="en" />

    <div class="legal-page__inner">
      <header class="legal-page__hero">
        <a class="legal-page__back" href="/">retour au site</a>
        <p class="legal-page__eyebrow">information légale</p>
        <h1>Mentions légales</h1>
        <p class="legal-page__lead">
          La présente page s'applique à la version actuelle du site OSMK, utilisé comme portfolio
          créatif, galerie de photographies et point de contact pour des demandes de collaboration,
          de casting ou de sourcing.
        </p>
        <LegalLinks locale="fr" />
      </header>

      <div class="legal-page__sections">
        <section class="legal-block">
          <h2>Édition du site</h2>
          <dl class="legal-definition">
            <dt>Nom du site</dt>
            <dd>OSMK</dd>

            <dt>Responsable / titulaire</dt>
            <dd>Precious Osemeke</dd>

            <dt>Email</dt>
            <dd>
              <a href="mailto:hellocontactosmk@gmail.com">hellocontactosmk@gmail.com</a>
            </dd>

            <dt>Instagram</dt>
            <dd>
              <a href="https://www.instagram.com/osmk_art/" target="_blank" rel="noreferrer">
                @osmk_art
              </a>
            </dd>
          </dl>
        </section>

        <section class="legal-block">
          <h2>Objet du site</h2>
          <p>
            Le site OSMK présente un univers artistique, des séries photographiques et un
            formulaire de prise de contact pour des candidatures, collaborations créatives et
            demandes autour de pièces seconde main.
          </p>
          <p>
            Le site fonctionne comme vitrine créative et point de contact. Aucune vente en ligne,
            aucun paiement direct et aucun compte client ne sont proposés sur le site dans sa
            version actuelle.
          </p>
          <p>
            Les échanges présentés ou préparés depuis ce site relèvent principalement de prises de
            contact, de collaborations et d'échanges de services autour de la photo, du stylisme
            et de la sélection de pièces.
          </p>
        </section>

        <section class="legal-block">
          <h2>Hébergement</h2>
          <p>
            Le site est hébergé sur <strong>Vercel</strong>.
          </p>
          <p>
            Hébergeur technique : <strong>Vercel Inc.</strong>
          </p>
          <p>
            Adresse de l'hébergeur : <strong>440 N Barranca Ave #4133, Covina, CA 91723, United States</strong>
          </p>
          <p>
            Site de l'hébergeur :
            <a href="https://vercel.com" target="_blank" rel="noreferrer">vercel.com</a>
          </p>
          <p>
            Contact hébergeur :
            <a href="mailto:privacy@vercel.com">privacy@vercel.com</a>
          </p>
        </section>

        <section class="legal-block">
          <h2>Formulaire et transmission des demandes</h2>
          <p>
            Les prises de contact, candidatures et demandes reçues via le formulaire sont destinées
            à OSMK et envoyées à l'adresse
            <a href="mailto:hellocontactosmk@gmail.com">hellocontactosmk@gmail.com</a>.
          </p>
          <p>
            Le formulaire est traité par l'API du site hébergée sur Vercel, puis transmis par
            courrier électronique via un service <strong>SMTP</strong> vers la boîte
            <a href="mailto:hellocontactosmk@gmail.com">hellocontactosmk@gmail.com</a>.
          </p>
          <p>
            Les fichiers joints sont limités à une taille totale raisonnable afin d'assurer la
            bonne transmission et la sécurité technique du service.
          </p>
        </section>

        <section class="legal-block">
          <h2>Propriété intellectuelle</h2>
          <p>
            Sauf mention contraire, les textes, photographies, éléments visuels, logo, direction
            artistique et mise en page présents sur ce site sont protégés par les droits de
            propriété intellectuelle applicables.
          </p>
          <p>
            Toute reproduction, adaptation, republication, extraction ou utilisation, totale ou
            partielle, sans autorisation préalable écrite, est interdite sauf dans les cas permis
            par la loi.
          </p>
        </section>

        <section class="legal-block">
          <h2>Droit à l'image</h2>
          <p>
            Les photographies représentant des personnes ne peuvent pas être réutilisées,
            diffusées ou republiées sans autorisation adaptée. Si vous estimez qu'une image porte
            atteinte à vos droits, vous pouvez contacter l'éditeur du site à l'adresse email
            ci-dessus.
          </p>
        </section>

        <section class="legal-block">
          <h2>Responsabilité</h2>
          <p>
            L'éditeur s'efforce de fournir des informations aussi exactes que possible, mais ne
            garantit pas l'absence totale d'erreurs, d'omissions ou d'indisponibilités temporaires.
          </p>
          <p>
            Les liens externes présents sur le site sont proposés à titre informatif. L'éditeur
            n'exerce pas de contrôle sur leur contenu ni sur leurs politiques propres.
          </p>
        </section>

        <section class="legal-block">
          <h2>Crédits</h2>
          <p>
            Direction artistique et univers OSMK : Precious Osemeke.
          </p>
          <p>
            Site créé par
            <a href="https://www.instagram.com/aa.webagence/" target="_blank" rel="noreferrer">
              A&amp;A web agence
            </a>
            .
          </p>
        </section>
      </div>

      <footer class="legal-page__footer">
        <p>{currentYear} OSMK. Portfolio créatif, galerie et prises de contact.</p>
        <LegalLinks locale="fr" />
      </footer>
    </div>
  </main>
</BaseLayout>
